{
	"name": "detain/myadmin-lxc-vps",
	"type": "myadmin-plugin",
	"description": "MyAdmin LXC VPS plugin — provides LXC (Linux Containers) virtual private server provisioning, management, and billing integration for the MyAdmin control panel.",
	"keywords": [
		"lxc",
		"vps",
		"containers",
		"virtualization",
		"myadmin",
		"administration",
		"hosting"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminLxc\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminLxc\\Tests\\": "tests/"
		}
	}
}
